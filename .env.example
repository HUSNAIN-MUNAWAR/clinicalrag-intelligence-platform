# Backend
CLINICALRAG_APP_NAME="ClinicalRAG Intelligence Platform"
CLINICALRAG_ENV=local
CLINICALRAG_DATABASE_URL=sqlite:///./data/clinicalrag.db
CLINICALRAG_DATA_DIR=./data
CLINICALRAG_VECTOR_STORE=local
CLINICALRAG_CHUNK_SIZE=900
CLINICALRAG_CHUNK_OVERLAP=160
CLINICALRAG_TOP_K=6
CLINICALRAG_SAFETY_STRICTNESS=strict
CLINICALRAG_LLM_PROVIDER=retrieval_only
# Optional: ollama | openai_compatible
CLINICALRAG_OLLAMA_BASE_URL=http://localhost:11434
CLINICALRAG_OLLAMA_MODEL=llama3.1
CLINICALRAG_OPENAI_COMPATIBLE_BASE_URL=
CLINICALRAG_OPENAI_COMPATIBLE_API_KEY=
CLINICALRAG_OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
NEXT_PUBLIC_API_URL=http://localhost:8000
